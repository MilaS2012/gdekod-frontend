# =============================================================================
# Шаблон переменных окружения для скриптов деплоя.
#
# Использование:
#   1. cp deploy/.env.example deploy/.env
#   2. Заполнить deploy/.env реальными значениями.
#   3. deploy/.env в .gitignore — НЕ коммитить.
#
# Где взять значения — см. deploy/README.md → раздел «Чек-лист подготовки».
# =============================================================================

# ID каталога в Yandex Cloud, в котором лежит bucket.
# Получить: yc resource-manager folder list  (поле ID).
YC_FOLDER_ID=b1g00000000000000000

# Имя bucket в Yandex Object Storage. Глобально уникальное в YC.
# Только [a-z0-9.-], не начинаться/заканчиваться с '.' или '-'.
YC_BUCKET_NAME=gdekod-frontend

# ID CDN-ресурса. Заполняется ПОСЛЕ создания CDN (шаг 4 в setup-bucket.sh).
# Если пусто — деплой пройдёт, инвалидация CDN будет пропущена.
# Получить: yc cdn resource list
YC_CDN_RESOURCE_ID=

# OAuth-токен Yandex Cloud (необязательно).
# Если пусто — используется активный профиль `yc config profile list`.
# Создать: https://cloud.yandex.ru/docs/cli/operations/authentication/user
# В прод/CI — всегда через Lockbox / GitHub Actions secrets, не в .env.
YC_TOKEN=
